// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  USER
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  LEAD
  PROSPECT
  CHURNED
}

enum ClientPriority {
  HIGH
  MEDIUM
  LOW
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  URGENT
  HIGH
  MEDIUM
  LOW
}

enum MeetingType {
  CALL
  VIDEO
  IN_PERSON
  OTHER
}

enum ReminderType {
  TASK
  MEETING
  CLIENT
  CUSTOM
}

enum DocumentType {
  PDF
  WORD
  IMAGE
  OTHER
}

enum ActivityType {
  CLIENT_CREATED
  CLIENT_UPDATED
  CLIENT_DELETED
  TASK_CREATED
  TASK_UPDATED
  TASK_COMPLETED
  TASK_DELETED
  MEETING_CREATED
  MEETING_UPDATED
  MEETING_DELETED
  NOTE_CREATED
  NOTE_DELETED
  DOCUMENT_UPLOADED
  REMINDER_CREATED
}

// ─── MODELS ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(USER)
  settings      Json?     @default("{}")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  clients       Client[]
  tasks         Task[]
  meetings      Meeting[]
  notes         Note[]
  reminders     Reminder[]
  documents     Document[]
  activityLogs  ActivityLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Client {
  id          String         @id @default(cuid())
  userId      String
  firstName   String
  lastName    String
  email       String?
  phone       String?
  address     String?
  company     String?
  status      ClientStatus   @default(LEAD)
  priority    ClientPriority @default(MEDIUM)
  notes       String?        @db.Text
  avatarUrl   String?
  lastContact DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks         Task[]
  meetings      Meeting[]
  clientNotes   Note[]
  reminders     Reminder[]
  documents     Document[]
  tags          ClientTag[]
  activityLogs  ActivityLog[]

  @@index([userId])
  @@index([status])
}

model Tag {
  id        String      @id @default(cuid())
  name      String
  color     String      @default("#6366f1")
  userId    String
  createdAt DateTime    @default(now())

  clients   ClientTag[]

  @@unique([name, userId])
}

model ClientTag {
  clientId  String
  tagId     String
  assignedAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([clientId, tagId])
}

model Task {
  id          String       @id @default(cuid())
  userId      String
  clientId    String?
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  category    String?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  reminders Reminder[]

  @@index([userId])
  @@index([clientId])
  @@index([status])
  @@index([dueDate])
}

model Meeting {
  id          String      @id @default(cuid())
  userId      String
  clientId    String?
  title       String
  description String?     @db.Text
  type        MeetingType @default(CALL)
  startTime   DateTime
  endTime     DateTime?
  location    String?
  color       String?     @default("#6366f1")
  notes       String?     @db.Text
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  reminders Reminder[]

  @@index([userId])
  @@index([clientId])
  @@index([startTime])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  clientId  String?
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clientId])
}

model Reminder {
  id          String       @id @default(cuid())
  userId      String
  clientId    String?
  taskId      String?
  meetingId   String?
  title       String
  description String?
  type        ReminderType @default(CUSTOM)
  remindAt    DateTime
  isRead      Boolean      @default(false)
  isDismissed Boolean      @default(false)
  createdAt   DateTime     @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client  Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  task    Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  meeting Meeting? @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([remindAt])
  @@index([isRead])
}

model Document {
  id           String       @id @default(cuid())
  userId       String
  clientId     String?
  name         String
  originalName String
  url          String
  size         Int
  mimeType     String
  type         DocumentType @default(OTHER)
  createdAt    DateTime     @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clientId])
}

model ActivityLog {
  id         String       @id @default(cuid())
  userId     String
  clientId   String?
  type       ActivityType
  title      String
  description String?
  metadata   Json?
  createdAt  DateTime     @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([clientId])
  @@index([createdAt])
}
